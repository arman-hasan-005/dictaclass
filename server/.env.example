# ─── Server ───────────────────────────────────────────────────
PORT=5000

# ─── MongoDB Atlas ────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/dictaclass?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# ─────────────────────────────────────────────────────────────
# TTS — 3-level fallback chain (server tries in this order):
#
#   Priority 1 → ElevenLabs       (best quality, paid)
#   Priority 2 → Google Cloud TTS (4M chars/month FREE on Standard voices)
#   Priority 3 → Browser voice    (client SpeechSynthesis, free, unlimited)
#
# You can leave any key blank — the server automatically skips that provider.
# ─────────────────────────────────────────────────────────────

# ── Priority 1: ElevenLabs ────────────────────────────────────
# Get from: https://elevenlabs.io → Profile → API Key
# Leave blank to skip ElevenLabs entirely
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_ID_FEMALE=G7jshfVWesI7sxKt8G0p
ELEVENLABS_VOICE_ID_MALE=9bpI4iGoJH6lcXRzpbV4

# ── Priority 2: Google Cloud Text-to-Speech ───────────────────
# How to get:
#   1. Go to https://console.cloud.google.com
#   2. Create or select a project
#   3. Search "Cloud Text-to-Speech API" → Enable it
#   4. Go to APIs & Services → Credentials → Create Credentials → API Key
#   5. (Recommended) Restrict key to "Cloud Text-to-Speech API"
#
# Free tier: 4,000,000 chars/month (Standard) | 1,000,000 chars/month (WaveNet)
# WaveNet voices are used by default — sound more natural
# Switch to Standard in ttsController.js if you need the 4M free tier
#
# NOTE: This is a DIFFERENT key from GOOGLE_VISION_API_KEY.
#       You can use the same key if it has both APIs enabled,
#       or create separate restricted keys for better security.
# Leave blank to skip Google TTS and use browser voice
GOOGLE_TTS_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxx

# ── Priority 3: Browser SpeechSynthesis ──────────────────────
# No key needed — built into every browser. Always available as last resort.

# ─── Google Vision OCR ───────────────────────────────────────
# Separate from TTS — only used for handwriting recognition in notebook upload
# Get from: https://console.cloud.google.com → Enable "Cloud Vision API"
GOOGLE_VISION_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxx

# ─── CORS ────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
